# Docker Compose environment variables
NODE_ENV=production
LOG_LEVEL=info

# Database
DB_PASSWORD=changeme_in_production
DB_PORT=5432

# Backend URLs
BACKEND_PORT=4000
FRONTEND_PORT=80
FRONTEND_URL=http://localhost
PUBLIC_URL=http://localhost:4000
BASE_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost,http://localhost:4000

# Security (MUST change these in production)
JWT_SECRET=change_me_generate_new_value_in_production

# Frontend
VITE_API_URL=http://localhost:4000

# Optional services (leave empty to disable)
RESEND_API_KEY=
EMAIL_FROM=Church System <no-reply@example.com>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_MODO=development
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
TWILIO_ACCOUNT_SID=
