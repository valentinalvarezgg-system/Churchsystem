# ─────────────────────────────────────────────────────────────
# Church System - Environment Configuration
# ─────────────────────────────────────────────────────────────
# CRITICAL: Copy to .env and customize for your environment
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# SERVER CONFIGURATION
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────
# SECURITY (REQUIRED)
# ─────────────────────────────────────────────────────────────
# Generate JWT_SECRET with: openssl rand -hex 32
# Production deployments MUST have a unique, strong JWT_SECRET
JWT_SECRET="CHANGE_ME_GENERATE_NEW_VALUE_IN_PRODUCTION"

# Comma-separated list of allowed origins for CORS
# Default: localhost (dev only)
# Production: MUST set strict whitelist
ALLOWED_ORIGINS="https://churchsystem.com.ar,https://www.churchsystem.com.ar,http://localhost:5173"
# Alias de CORS_ORIGINS (mismo efecto, cualquiera de los dos funciona)
CORS_ORIGINS=

# ─────────────────────────────────────────────────────────────
# DATABASE (REQUIRED)
# ─────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (o cualquier Postgres compatible)
# Format: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=
# Tamaño máximo del pool de conexiones (default: 5)
PG_POOL_MAX=5

# ─────────────────────────────────────────────────────────────
# FRONTEND URLS
# ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
PUBLIC_URL=http://localhost:4000
BASE_URL=http://localhost:4000

# ─────────────────────────────────────────────────────────────
# EMAIL SERVICE (Resend)
# ─────────────────────────────────────────────────────────────
# Get key from: https://resend.com
# Leave empty for development (emails won't send)
RESEND_API_KEY=
EMAIL_FROM="Church System <no-reply@churchsystem.com.ar>"
RESEND_INBOUND_SECRET=
OWNER_REPORTS_EMAIL=reports@churchsystem.com.ar
SUPPORT_EMAIL=soporte@churchsystem.com.ar

# ─────────────────────────────────────────────────────────────
# OAUTH PROVIDERS
# ─────────────────────────────────────────────────────────────
# Optional: Leave empty to disable OAuth

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────
# PAYMENT SERVICE (MercadoPago)
# ─────────────────────────────────────────────────────────────
# Optional: Leave empty for development
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_MODO=development
MP_WEBHOOK_SECRET=

# Optional: override auto-fetched USD/ARS rate (uses BCRA official API by default)
COTIZACION_USD_ARS=

# ─────────────────────────────────────────────────────────────
# PUSH NOTIFICATIONS
# ─────────────────────────────────────────────────────────────
# Optional: Generate via web-push CLI
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# ─────────────────────────────────────────────────────────────
# AI INTEGRATIONS
# ─────────────────────────────────────────────────────────────
# Optional: Groq, Anthropic, or OpenAI for AI features
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────
# WHATSAPP CLOUD API (Meta oficial)
# ─────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_DISPLAY_PHONE_NUMBER=
META_VERIFIED_NAME=
META_GRAPH_VERSION=v23.0

# ─────────────────────────────────────────────────────────────
# SMS / WHATSAPP (Twilio legacy fallback)
# ─────────────────────────────────────────────────────────────
# Optional: keep only as temporary compatibility fallback
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ─────────────────────────────────────────────────────────────
# QR CHECK-IN
# ─────────────────────────────────────────────────────────────
# REQUIRED en producción: clave para firmar los tokens QR
# Generar con: openssl rand -hex 32
QR_SECRET=CHANGE_ME_GENERATE_NEW_VALUE

# ─────────────────────────────────────────────────────────────
# OAUTH (Apple Sign-In)
# ─────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=https://churchsystem.com.ar/api/oauth/apple/callback
